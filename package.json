{
  "name": "daisyui-vscode-snippets",
  "displayName": "DaisyUI HTML Snippets",
  "description": "Curated DaisyUI HTML snippets for VS Code with predictable prefixes, valid markup, and editable placeholders.",
  "version": "0.9.0",
  "publisher": "sjedt",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Jedt3D/daisyui-vscode-snippets",
  "bugs": {
    "url": "https://github.com/Jedt3D/daisyui-vscode-snippets/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jedt3D/daisyui-vscode-snippets.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Snippets"
  ],
  "keywords": [
    "daisyui",
    "tailwindcss",
    "html",
    "snippets",
    "components",
    "ui"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "scripts": {
    "generate": "node ./scripts/generate-snippets.mjs",
    "assets:generate": "python3 ./scripts/generate-marketplace-assets.py",
    "validate": "node ./scripts/validate-snippets.mjs",
    "build": "npm run generate && npm run validate",
    "package:vsix": "npm run build && npx @vscode/vsce package -o bin/daisyui-vscode-snippets.vsix",
    "release:check": "npm run build && npm run package:vsix",
    "publish:precheck": "npm run release:check",
    "publish:vsce": "npm run build && npx @vscode/vsce publish",
    "test": "npm run validate"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:html",
    "onCommand:daisyuiSnippets.insertSnippet",
    "onCommand:daisyuiSnippets.insertSnippetByCategory",
    "onCommand:daisyuiSnippets.previewSnippet",
    "onCommand:daisyuiSnippets.insertRecentSnippet",
    "onCommand:daisyuiSnippets.insertFavoriteSnippet",
    "onCommand:daisyuiSnippets.toggleFavoriteSnippet",
    "onCommand:daisyuiSnippets.insertPreset",
    "onCommand:daisyuiSnippets.previewPreset",
    "onCommand:daisyuiSnippets.switchTheme",
    "onCommand:daisyuiSnippets.insertSectionPattern",
    "onCommand:daisyuiSnippets.upgradeSelection"
  ],
  "contributes": {
    "commands": [
      {
        "command": "daisyuiSnippets.insertSnippet",
        "title": "DaisyUI: Insert Snippet",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.insertSnippetByCategory",
        "title": "DaisyUI: Browse Snippets by Category",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.previewSnippet",
        "title": "DaisyUI: Preview Snippet",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.insertRecentSnippet",
        "title": "DaisyUI: Insert Recent Snippet",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.insertFavoriteSnippet",
        "title": "DaisyUI: Insert Favorite Snippet",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.toggleFavoriteSnippet",
        "title": "DaisyUI: Toggle Favorite Snippet",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.insertPreset",
        "title": "DaisyUI: Insert Preset",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.previewPreset",
        "title": "DaisyUI: Preview Preset",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.switchTheme",
        "title": "DaisyUI: Switch Theme in Document",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.insertSectionPattern",
        "title": "DaisyUI: Insert Section Pattern",
        "category": "DaisyUI"
      },
      {
        "command": "daisyuiSnippets.upgradeSelection",
        "title": "DaisyUI: Upgrade Selected HTML",
        "category": "DaisyUI"
      }
    ]
  },
  "icon": "images/icon.png",
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
